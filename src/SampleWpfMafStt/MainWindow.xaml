<Window x:Class="SampleWpfMafStt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SampleWpfMafStt"
        mc:Ignorable="d"
        Title="WPF × MAF × Moonshine STT サンプル"
        Height="720" Width="1150">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom" Height="26">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="準備中…" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="ModelText" Text="" Foreground="Gray" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="360" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="3*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="8">
                <TextBlock DockPanel.Dock="Top"
                           Text="音声入力 (Push-To-Talk)"
                           FontWeight="Bold"
                           Margin="0,0,0,4" />

                <!-- ボタン領域: partial → ボタン → ヒント の順 (ボタンのすぐ上に partial) -->
                <Border DockPanel.Dock="Bottom"
                        Margin="0,8,0,0"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8">
                    <StackPanel>
                        <Border BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Background="#F8F8F8"
                                Padding="6"
                                MinHeight="32"
                                Margin="0,0,0,8">
                            <TextBlock x:Name="PartialText"
                                       Text=""
                                       Foreground="#888888"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap" />
                        </Border>
                        <Button x:Name="PttButton"
                                Content="🎤 押している間だけ録音"
                                FontSize="16"
                                Height="56"
                                PreviewMouseDown="PttButton_PreviewMouseDown"
                                PreviewMouseUp="PttButton_PreviewMouseUp"
                                LostMouseCapture="PttButton_LostMouseCapture"
                                IsEnabled="False" />
                        <TextBlock x:Name="HintText"
                                   Margin="0,6,0,0"
                                   FontSize="11"
                                   Foreground="Gray"
                                   Text="ボタンを押している間に話してください。離すと認識→送信されます。" />
                    </StackPanel>
                </Border>

                <Border BorderBrush="#CCCCCC" BorderThickness="1">
                    <ScrollViewer x:Name="HistoryScroll" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HistoryList" Margin="4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </DockPanel>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="#DDDDDD" />

            <DockPanel Grid.Column="2" Margin="8">
                <TextBlock DockPanel.Dock="Top"
                           Text="操作キャンバス (LLM がここを変更します)"
                           FontWeight="Bold"
                           Margin="0,0,0,4" />
                <Border BorderBrush="#CCCCCC" BorderThickness="1">
                    <Canvas x:Name="TargetCanvas" Background="White" ClipToBounds="True" />
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
